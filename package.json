{
  "name": "hermes-ai-agent",
  "displayName": "Hermes AI Agent",
  "description": "VS Code sidebar for the Hermes AI agent. Streams chat, runs tools, manages sessions. Multi-model (Claude, Codex). Communicates over ACP.",
  "version": "3.3.0",
  "publisher": "joaompfp",
  "author": {
    "name": "Joao Peixoto",
    "url": "https://github.com/joaompfp"
  },
  "contributors": [
    {
      "name": "Stefan van Biljon",
      "url": "https://github.com/stefanpieter"
    }
  ],
  "license": "MIT",
  "keywords": [
    "ai agent",
    "coding assistant",
    "autonomous agent",
    "claude",
    "codex",
    "copilot alternative",
    "pair programmer",
    "llm",
    "tool use",
    "chat",
    "hermes",
    "acp",
    "agent client protocol",
    "sidebar chat",
    "streaming",
    "remote ssh"
  ],
  "homepage": "https://github.com/stefanpieter/hermes-vscode",
  "bugs": {
    "url": "https://github.com/stefanpieter/hermes-vscode/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stefanpieter/hermes-vscode"
  },
  "icon": "resources/hermes-logo-128.png",
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "qna": "https://github.com/stefanpieter/hermes-vscode/issues",
  "contributes": {
    "commands": [
      {
        "command": "hermes.openChat",
        "title": "Hermes: Open Chat"
      },
      {
        "command": "hermes.newSession",
        "title": "Hermes: New Session"
      },
      {
        "command": "hermes.selectProfile",
        "title": "Hermes: Select Profile"
      },
      {
        "command": "hermes.selectEditApprovalMode",
        "title": "Hermes: Select Edit Approval Mode"
      },
      {
        "command": "hermes.restartAgent",
        "title": "Hermes: Restart Agent"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes",
          "title": "Hermes Agent",
          "icon": "resources/hermes-icon.svg"
        }
      ]
    },
    "views": {
      "hermes": [
        {
          "type": "webview",
          "id": "hermes.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Hermes",
      "properties": {
        "hermes.path": {
          "type": "string",
          "default": "hermes",
          "scope": "machine-overridable",
          "description": "Trusted absolute path to the Hermes binary."
        },
        "hermes.profile": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Optional Hermes profile to use for ACP sessions. Empty uses Hermes's current/default profile."
        },
        "hermes.editApprovalMode": {
          "type": "string",
          "enum": [
            "default",
            "accept_edits",
            "dont_ask"
          ],
          "enumDescriptions": [
            "Ask before every file edit.",
            "Automatically allow workspace and temporary-file edits, while still asking for sensitive paths.",
            "Automatically allow file edits for the session except sensitive paths."
          ],
          "default": "default",
          "scope": "machine-overridable",
          "description": "ACP file-edit approval mode. Change it with Hermes: Select Edit Approval Mode."
        },
        "hermes.debugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable diagnostic ACP logs in the Hermes output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production",
    "lint": "tsc --noEmit",
    "secrets": "secretlint --secretlintrc .secretlintrc.json \"*.{md,json,js,ts,yml,yaml}\" \"src/**/*.{ts,json}\" \"scripts/**/*.{js,mjs,cjs,ts}\" \"tests/**/*.ts\" \".github/**/*.{md,yml,yaml}\" \"docs/**/*.md\" \"resources/**/*.md\"",
    "test": "npm run test:profile && npm run test:background",
    "posttest": "node -e \"require('node:fs').rmSync('out-test', { recursive: true, force: true })\"",
    "dev": "webpack --mode development --watch",
    "package": "vsce package --no-dependencies",
    "package:verify": "npm run package -- --out hermes-ai-agent-ci.vsix && vsce ls",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run secrets && npm test && npm run build && npm run audit && npm run package:verify",
    "test:profile": "tsc --module commonjs --target ES2020 --types node --skipLibCheck --esModuleInterop --strict --outDir out-test tests/acpLaunchArgs.test.ts tests/profileUi.test.ts src/acpLaunchArgs.ts src/profileUi.ts && node out-test/tests/acpLaunchArgs.test.js && node out-test/tests/profileUi.test.js",
    "test:background": "node scripts/run-background-tests.mjs"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^10.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "secretlint": "^10.2.2",
    "ts-loader": "^9.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "marked": "^17.0.6"
  }
}
